# Copy to .env.local and fill in values. Never commit .env.local.
#
# Local email testing (booking / contact / review) uses Resend.
# In development, BOOKING_TO and REVIEW_TO are REQUIRED — the mailer will
# not fall back to info@theplumbingstars.com outside production.

# Paste from Vercel Dashboard → Environment Variables (Production/Preview).
# `vercel env pull` redacts this key as [SENSITIVE], so paste manually or:
#   npx vercel env add RESEND_API_KEY development
RESEND_API_KEY=

# Match production From address (verified domain on Resend)
EMAIL_FROM=The Plumbing Stars <noreply@theplumbingstars.com>

# Your personal test inbox (required for local/dev sends)
BOOKING_TO=
REVIEW_TO=

# Optional Gmail fallback if Resend is unset
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
